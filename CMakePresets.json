{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (Apple Clang)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Apple Clang)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Debug (MinGW64 → Windows x86_64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "toolchainFile": "${sourceDir}/cmake/mingw64-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "targets": ["Windows-Capture"]
    }
  ]
}
